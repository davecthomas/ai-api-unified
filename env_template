########################################################################
#   CORE ENGINE SELECTION
########################################################################
# Which embedding model family?   openai | titan | google-gemini
# EMBEDDING_ENGINE=titan
EMBEDDING_ENGINE=google-gemini


########################################################################
#   OPENAI / TITAN / Google API CREDENTIALS
########################################################################
# --- OpenAI ---
OPENAI_API_KEY=
# Geo-residency constraint (optional: US | USA | United States)
AI_API_GEO_RESIDENCY=
GOOGLE_GEMINI_API_KEY=
GOOGLE_AUTH_METHOD=api_key
COMPLETIONS_ENGINE=google-gemini

# Generic AI settings
# Embedding model name (text-embedding-3-small | amazon.titan-embed-text-v2:0 | gemini-embedding-001)
EMBEDDING_MODEL_NAME=gemini-embedding-001
# EMBEDDING_MODEL_NAME=amazon.titan-embed-text-v2:0
# Completions model name (gpt-4o-mini | amazon.nova-micro-v1:0 | amazon.nova-lite-v1:0 | gemini-2.5-flash)
COMPLETIONS_MODEL_NAME=gemini-2.5-flash
# COMPLETIONS_MODEL_NAME=amazon.nova-lite-v1:0
# Embedding dimensions (1536 for OpenAI | 1024 for Titan | 3072 default for Gemini)
# Leave unset to use the provider default for the selected engine.
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_DIMENSIONS=3072
# Vector metric (cosine for Pinecone | cosinesimil for OpenSearch | COSINE for Redis)
# VECTOR_METRIC=cosinesimil
VECTOR_METRIC=cosine

AWS_REGION=us-east-1

# AWS credentials for Bedrock - these are ephermeral and must be set at runtime. 
# Read more here: https://docs.aws.amazon.com/cli/latest/userguide/cli-configure-envvars.html
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ----------------------------------------
# AI Voice Settings
# ----------------------------------------
# ElevenLabs API key
ELEVEN_LABS_API_KEY=

# Voice engine: "elevenlabs", "google", "openai", "azure"
AI_VOICE_ENGINE=google

# Language code (e.g. en, de)
AI_VOICE_LANGUAGE=en

########################################################################
#   Google AI Voice Settings
# OSS defaults to API-key auth for Google. Service-account / Vertex mode remains
# available by setting GOOGLE_AUTH_METHOD=service_account and providing the
# usual Google credentials below.
# GOOGLE_APPLICATION_CREDENTIALS=credentials/<filename>.json
# GOOGLE_PROJECT_ID=
# GOOGLE_LOCATION=us-central1
# Preferred Google TTS model
DEFAULT_GEMINI_TTS_MODEL=gemini-2.5-pro-tts

########################################################################
#   Google Gemini AI Settings (Completions & Embeddings)
# Uses GOOGLE_GEMINI_API_KEY by default.
# COMPLETIONS_ENGINE=google-gemini
# EMBEDDING_ENGINE=google-gemini
# Default models:
#   Completions: gemini-2.5-flash
#   Embeddings: gemini-embedding-001

########################################################################
# OpenAI AI Voice Settings
OPENAI_API_KEY=
# AI_VOICE_ENGINE=openai

########################################################################
# Azure AI Voice Settings
# AI_VOICE_ENGINE=azure
MICROSOFT_COGNITIVE_SERVICES_API_KEY=your-microsoft-cognitive-services-api-key
MICROSOFT_COGNITIVE_SERVICES_API_KEY_2=your-microsoft-cognitive-services-api-key-2
MICROSOFT_COGNITIVE_SERVICES_REGION=eastus
MICROSOFT_COGNITIVE_SERVICES_ENDPOINT=https://eastus.api.cognitive.microsoft.com/

# Image engine: openai | nova-canvas | google-gemini
IMAGE_ENGINE=google-gemini
# image model used for image generation requests: openai: gpt-image-1 ; amazon nova: amazon.nova-canvas-v1:0 ; google gemini: imagen-4.0-generate-001
IMAGE_MODEL_NAME=imagen-4.0-generate-001
